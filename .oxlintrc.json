{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["dist", "coverage", "node_modules"],
  "categories": {
    "correctness": "error"
  },
  "overrides": [
    {
      "files": ["**/*.types.ts"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
