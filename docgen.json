{
  "$schema": "./node_modules/@effect/docgen/schema.json",
  "exclude": ["src/**/*.test.ts", "src/internal/**/*.ts", "src/index.ts"],
  "parseCompilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "lib": ["es2022"],
    "strict": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": false
  },
  "examplesCompilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "lib": ["es2022"],
    "exactOptionalPropertyTypes": false
  }
}
