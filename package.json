{
  "name": "@thomasfosterau/effect-jsonapi",
  "version": "0.0.0",
  "description": "Type-safe, spec-compliant JSON:API v1.1 on Effect's HttpApi.",
  "keywords": [
    "api",
    "effect",
    "functional-programming",
    "json-api",
    "jsonapi",
    "schema",
    "typescript"
  ],
  "homepage": "https://github.com/thomasfosterau/effect-jsonapi#readme",
  "bugs": {
    "url": "https://github.com/thomasfosterau/effect-jsonapi/issues"
  },
  "license": "MIT",
  "author": "Thomas Foster",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasfosterau/effect-jsonapi.git"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.test.json && pnpm --filter \"./examples/*\" run typecheck",
    "lint": "oxlint --deny-warnings src test examples",
    "lint:fix": "oxlint --fix src test examples",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run && pnpm --filter \"./examples/*\" run test",
    "test:watch": "vitest",
    "docgen": "docgen",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm publish && changeset tag",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@effect/docgen": "^0.5.2",
    "@types/node": "^26.0.0",
    "effect": "^4.0.0-beta.84",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.84"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
